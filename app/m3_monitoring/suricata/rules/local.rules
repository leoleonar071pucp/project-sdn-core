alert tcp any any -> $HOME_NET any (msg:"SDN DEMO TCP port scan"; flags:S; threshold:type both, track by_src, count 20, seconds 10; classtype:attempted-recon; sid:9000001; rev:1;)
alert http any any -> $HOME_NET any (msg:"SDN DEMO possible SQL injection"; http.uri; pcre:"/(\%27)|(')|(--)|(\%23)|(#)|(\bunion\b.*\bselect\b)/Ui"; classtype:web-application-attack; sid:9000002; rev:1;)
alert http any any -> $HOME_NET any (msg:"SDN DEMO suspicious command in HTTP"; http.request_body; pcre:"/\b(cmd\.exe|powershell|wget|curl|\/bin\/sh|nc\s+-e)\b/Ui"; classtype:web-application-attack; sid:9000003; rev:1;)
alert http any any -> $HOME_NET any (msg:"SDN DEMO malware marker"; http.request_body; content:"SDN-DEMO-MALWARE"; nocase; classtype:trojan-activity; sid:9000004; rev:1;)
